{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/TheDarkniteFalls/evidencegate/schemas/evidencegate-attestation-v0.schema.json",
  "title": "EvidenceGate unsigned in-toto attestation profile v0",
  "description": "An unsigned in-toto Statement binding one EvidenceGate v1 receipt digest to one Git subject. Schema validity is not identity authentication.",
  "type": "object",
  "additionalProperties": false,
  "required": ["_type", "subject", "predicateType", "predicate"],
  "properties": {
    "_type": {"const": "https://in-toto.io/Statement/v1"},
    "subject": {
      "type": "array",
      "minItems": 1,
      "maxItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "digest"],
        "properties": {
          "name": {"type": "string", "pattern": "\\S"},
          "digest": {
            "type": "object",
            "additionalProperties": false,
            "required": ["gitCommit"],
            "properties": {
              "gitCommit": {"$ref": "#/$defs/gitSha"}
            }
          }
        }
      }
    },
    "predicateType": {
      "const": "https://github.com/TheDarkniteFalls/evidencegate/attestation/v0"
    },
    "predicate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "profile",
        "receipt",
        "base_sha",
        "head_sha",
        "issued_at",
        "expires_at",
        "claimed_issuer"
      ],
      "properties": {
        "profile": {"const": "evidencegate_attestation_v0"},
        "receipt": {
          "type": "object",
          "additionalProperties": false,
          "required": ["media_type", "sha256"],
          "properties": {
            "media_type": {
              "const": "application/vnd.evidencegate.receipt.v1+json"
            },
            "sha256": {
              "type": "string",
              "pattern": "^[0-9a-f]{64}$"
            }
          }
        },
        "base_sha": {"$ref": "#/$defs/gitSha"},
        "head_sha": {"$ref": "#/$defs/gitSha"},
        "issued_at": {"$ref": "#/$defs/utcTimestamp"},
        "expires_at": {"$ref": "#/$defs/utcTimestamp"},
        "claimed_issuer": {"type": "string", "pattern": "\\S"}
      }
    }
  },
  "$defs": {
    "gitSha": {
      "type": "string",
      "pattern": "^[0-9a-fA-F]{40}$"
    },
    "utcTimestamp": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"
    }
  }
}
