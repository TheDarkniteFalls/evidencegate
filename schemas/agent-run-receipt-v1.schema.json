{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/TheDarkniteFalls/evidencegate/schemas/agent-run-receipt-v1.schema.json",
  "title": "EvidenceGate Git-change receipt v1",
  "description": "A revision-bound, human-reviewed receipt for one Git change. Extensions are recorded but never interpreted as gate authority.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "summary",
    "subject",
    "scope",
    "files_touched",
    "checks",
    "claims",
    "risks",
    "human_review",
    "public_safety"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "summary": {
      "$ref": "#/$defs/nonEmptyText"
    },
    "subject": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "base_sha", "head_sha"],
      "properties": {
        "type": {
          "const": "git_change"
        },
        "base_sha": {
          "$ref": "#/$defs/gitSha"
        },
        "head_sha": {
          "$ref": "#/$defs/gitSha"
        }
      }
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["allowed_paths", "protected_prefixes"],
      "properties": {
        "allowed_paths": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/repoPath"
          }
        },
        "protected_prefixes": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/repoPath"
          }
        }
      }
    },
    "files_touched": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/repoPath"
      }
    },
    "checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "name",
          "command",
          "status",
          "summary",
          "scope",
          "revision",
          "required"
        ],
        "properties": {
          "id": {
            "$ref": "#/$defs/id"
          },
          "name": {
            "$ref": "#/$defs/nonEmptyText"
          },
          "command": {
            "$ref": "#/$defs/nonEmptyText"
          },
          "status": {
            "enum": ["failed", "passed", "skipped", "unknown"]
          },
          "summary": {
            "$ref": "#/$defs/nonEmptyText"
          },
          "scope": {
            "$ref": "#/$defs/nonEmptyText"
          },
          "revision": {
            "$ref": "#/$defs/gitSha"
          },
          "required": {
            "type": "boolean"
          }
        }
      }
    },
    "claims": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "text", "evidence_refs"],
        "properties": {
          "id": {
            "$ref": "#/$defs/id"
          },
          "text": {
            "$ref": "#/$defs/nonEmptyText"
          },
          "evidence_refs": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "$ref": "#/$defs/id"
            }
          }
        }
      }
    },
    "risks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/nonEmptyText"
      }
    },
    "human_review": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "reviewer", "reviewed_head_sha", "summary"],
      "properties": {
        "status": {
          "enum": ["approved", "changes_requested", "pending"]
        },
        "reviewer": {
          "$ref": "#/$defs/nonEmptyText"
        },
        "reviewed_head_sha": {
          "$ref": "#/$defs/gitSha"
        },
        "summary": {
          "$ref": "#/$defs/nonEmptyText"
        }
      }
    },
    "public_safety": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "reviewed_head_sha", "summary"],
      "properties": {
        "status": {
          "enum": ["not_applicable", "pending", "reviewed"]
        },
        "reviewed_head_sha": {
          "$ref": "#/$defs/gitSha"
        },
        "summary": {
          "$ref": "#/$defs/nonEmptyText"
        }
      }
    },
    "extensions": {
      "type": "object",
      "description": "Namespaced, non-authoritative metadata ignored by EvidenceGate v1 validation, verification, and rendering.",
      "additionalProperties": true
    }
  },
  "$defs": {
    "nonEmptyText": {
      "type": "string",
      "pattern": "\\S"
    },
    "gitSha": {
      "type": "string",
      "pattern": "^[0-9a-fA-F]{40}$"
    },
    "id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
    },
    "repoPath": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!/)(?!\\s)(?!.*\\s$)(?!.*\\\\)(?!.*//)(?!.*(?:^|/)\\.\\.?(?:/|$))(?!.*[\\u0000-\\u001f]).+$"
    }
  }
}
